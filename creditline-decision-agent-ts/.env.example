# ── Anthropic ───────────────────────────────────────────────────────────────
# The live agent uses the Claude Code runtime: it runs with your local `claude`
# login OR an ANTHROPIC_API_KEY. The deterministic demo needs neither.
AGENT_MODEL=claude-opus-4-8
# ANTHROPIC_API_KEY=

# ── Environment DB (mimic_creditline) — the agent reads/writes via the MCP ───
# The MCP server connects with the LEAST-PRIVILEGE agent role.
MIMIC_DB_DSN=postgresql://creditline_agent:agent_demo_pw@localhost:5433/mimic_creditline

# Admin connection — used ONLY for seeding/initialisation and by the officer
# console, never handed to the agent.
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_USER=postgres
ADMIN_DB_PASSWORD=postgres

# How long creditline_request_approval blocks waiting for a human, in seconds.
APPROVAL_TIMEOUT_SECONDS=900
APPROVAL_POLL_SECONDS=2
