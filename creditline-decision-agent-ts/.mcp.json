{
  "mcpServers": {
    "mimic-creditline": {
      "command": "npx",
      "args": ["tsx", "src/mcp/server.ts"],
      "env": {
        "MIMIC_DB_DSN": "${MIMIC_DB_DSN:-postgresql://creditline_agent:agent_demo_pw@localhost:5433/mimic_creditline}",
        "APPROVAL_TIMEOUT_SECONDS": "${APPROVAL_TIMEOUT_SECONDS:-900}",
        "APPROVAL_POLL_SECONDS": "${APPROVAL_POLL_SECONDS:-2}"
      }
    }
  }
}
