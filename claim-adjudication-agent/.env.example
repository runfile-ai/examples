# ── Model (Claude Agent SDK) ─────────────────────────────────────────────────
# The live agent uses the Claude Code runtime: it runs with your local `claude`
# login OR an ANTHROPIC_API_KEY. The deterministic demo needs neither.
AGENT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ── Database (one Postgres, schemas ext.* and agent.*) ───────────────────────
CLAIMS_DB_DSN=postgresql://postgres:postgres@localhost:5433/claims

# Admin connection used by the seed to CREATE DATABASE (if the DSN above is not
# reachable yet). Reuses the shared local Postgres.
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_USER=postgres
ADMIN_DB_PASSWORD=postgres
CLAIMS_DB_NAME=claims

# Channel for the session (queue | batch).
CLAIMS_CHANNEL=queue

# Auto-finalize ceiling, in cents. A claim whose total plan-paid is at or below
# this AND whose every line is a clean 'pay' may finalize without a human. Any
# deny / reduce / pend, or a total above this, routes to a human reviewer.
AUTO_FINALIZE_CEILING_CENTS=20000

# How long a gated write (post_adjudication) blocks for a human, and poll, in seconds.
APPROVAL_TIMEOUT_SECONDS=900
APPROVAL_POLL_SECONDS=2
