# ── OpenAI ───────────────────────────────────────────────────────────────────
# Required only to run the live agent (npm run agent). The deterministic demo
# and the MCP/DB layers do not need a key.
# OPENAI_API_KEY=
AGENT_MODEL=gpt-4.1

# ── Shared environment DB (mimic_creditline) ─────────────────────────────────
# The same database the Claude and LangGraph builds use. The MCP server (spawned
# from the sibling base project) connects with the least-privilege agent role.
MIMIC_DB_DSN=postgresql://creditline_agent:agent_demo_pw@localhost:5433/mimic_creditline

# Admin DSN — used by the demo's officer override only, never handed to the agent.
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_USER=postgres
ADMIN_DB_PASSWORD=postgres

# How long creditline_request_approval blocks waiting for a human, in seconds.
APPROVAL_TIMEOUT_SECONDS=900
APPROVAL_POLL_SECONDS=2
