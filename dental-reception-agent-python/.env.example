# ── Model (Claude Agent SDK) ─────────────────────────────────────────────────
# The live agent uses the Claude Code runtime: it runs with your local `claude`
# login OR an ANTHROPIC_API_KEY. The deterministic demo needs neither.
AGENT_MODEL=claude-sonnet-4-6
# ANTHROPIC_API_KEY=

# ── Database (one Postgres, schemas ext.* and agent.*) ───────────────────────
DENTAL_DB_DSN=postgresql://postgres:postgres@localhost:5433/dental

# Admin connection used by the seed to CREATE DATABASE (if the DSN above is not
# reachable yet). Reuses the shared local Postgres.
ADMIN_DB_HOST=localhost
ADMIN_DB_PORT=5433
ADMIN_DB_USER=postgres
ADMIN_DB_PASSWORD=postgres
DENTAL_DB_NAME=dental

# Channel for the session (voice | chat | batch).
DENTAL_CHANNEL=voice

# How long a gated write (book / reschedule / cancel / update_contact) blocks
# for a human, and how often it polls, in seconds.
APPROVAL_TIMEOUT_SECONDS=900
APPROVAL_POLL_SECONDS=2

# Soft local hold TTL (minutes) — the agent's double-book defense.
HOLD_TTL_MINUTES=15
