{
  "name": "monitoring-agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Production monitoring agent (TypeScript, Claude Agent SDK) — triage Sentry-shaped issues, diagnose, and declare/resolve PagerDuty-shaped incidents through a human-gated, Halo-backed tool layer over a local Postgres.",
  "scripts": {
    "mcp": "tsx src/mcp/server.ts",
    "agent": "tsx src/agent/main.ts",
    "demo": "tsx src/scripts/run-demo.ts",
    "oncall": "tsx src/scripts/oncall-console.ts",
    "initdb": "tsx db/seed.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.3.162",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "pg": "^8.21.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
